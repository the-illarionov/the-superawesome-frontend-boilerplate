{
	"name": "backend",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "SHELL=/bin/sh chokidar \"**/*.ts\" -i \"./node_modules/**\" -i \"**/*.test.*\" --initial -c \"npm run kill && npm run dev-serve\"",
		"dev-serve": "vite-node src/main.ts",
		"kill": "pid=$(lsof -t -i :80); if [ $pid ]; then kill $pid; fi",
		"build": "tsc && vite build --ssr src/main.ts",
		"serve": "node dist/main.js",
		"test:unit": "vitest run",
		"test:unit:ui": "vitest --api.host 0.0.0.0 --api.port 80 --ui"
	},
	"devDependencies": {
		"@types/express": "^4.17.17",
		"@types/node": "^18.15.0",
		"@types/supertest": "^2.0.12",
		"@vitest/ui": "^0.29.2",
		"chokidar-cli": "^3.0.0",
		"supertest": "^6.3.3",
		"typescript": "^4.9.3",
		"vite": "^4.1.0",
		"vite-node": "^0.29.2",
		"vitest": "^0.29.2"
	},
	"dependencies": {
		"express": "^4.18.2"
	}
}
